# NexusOS kernel configuration (x86_64 generic)
# Apply with: make x86_64_defconfig && merge this file

CONFIG_LOCALVERSION="-nexusos"
CONFIG_DEFAULT_HOSTNAME="nexusos"

CONFIG_SMP=y
CONFIG_HYPERVISOR_GUEST=y
CONFIG_KVM_GUEST=y

CONFIG_EXT4_FS=y
CONFIG_BTRFS_FS=y
CONFIG_OVERLAY_FS=y

CONFIG_DRM=y
CONFIG_DRM_I915=y
CONFIG_DRM_AMDGPU=y
CONFIG_DRM_NOUVEAU=y

CONFIG_WIRELESS=y
CONFIG_CFG80211=y

CONFIG_CGROUPS=y
CONFIG_NAMESPACES=y
CONFIG_USER_NS=y
