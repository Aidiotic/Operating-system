# NexusOS kernel configuration (Asahi / Apple Silicon)
# Based on Asahi Linux kernel — apply with:
#   make ARCH=arm64 asahi_defconfig
#   scripts/kconfig --merge config/asahi.config build/kernel/asahi.config

CONFIG_LOCALVERSION="-nexusos"
CONFIG_DEFAULT_HOSTNAME="nexusos"

# Desktop
CONFIG_DRM=y
CONFIG_DRM_ASAHIGPU=y
CONFIG_SOUND=y
CONFIG_SND_SOC_APPLE=y

# Filesystems
CONFIG_EXT4_FS=y
CONFIG_BTRFS_FS=y
CONFIG_XFS_FS=y

# Networking
CONFIG_WIRELESS=y
CONFIG_CFG80211=y
CONFIG_MAC80211=y

# System
CONFIG_CGROUPS=y
CONFIG_NAMESPACES=y
CONFIG_USER_NS=y
CONFIG_SECCOMP=y
