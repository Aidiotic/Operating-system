# Pinned Asahi platform versions — update when tracking new Asahi stable.
ASAHI_LINUX_REPO=https://github.com/AsahiLinux/linux.git
ASAHI_LINUX_TAG=asahi-6.6.0-1
KERNEL_LOCALVERSION=-nexusos

ASAHI_REPO_URL=https://repo.asahilinux.org/debian/
ASAHI_REPO_SUITE=stable

# Set to 1 to install prebuilt Asahi kernel from repo instead of building from source.
ASAHI_KERNEL_USE_PREBUILT=0
