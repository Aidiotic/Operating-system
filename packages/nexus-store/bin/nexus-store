#!/usr/bin/env bash
# NexusOS Software Center — installs from the NexusOS APT repository and Debian.

set -euo pipefail

CATALOG="/usr/share/nexusos/catalog.json"
NEXUS_APT="/etc/apt/sources.list.d/nexusos.list"
KEYRING="/usr/share/keyrings/nexusos-archive-keyring.gpg"

log() { printf '[nexus-store] %s\n' "$*"; }
die() { printf '[nexus-store] ERROR: %s\n' "$*" >&2; exit 1; }

usage() {
  cat <<EOF
NexusOS Software Center

Usage:
  nexus-store                    Interactive software center
  nexus-store list               List catalog packages
  nexus-store refresh            Update NexusOS + Debian package indices
  nexus-store install <package>  Install a package
  nexus-store remove <package>   Remove a package
  nexus-store search <query>     Search package cache

Packages install from the NexusOS APT repo when configured (${NEXUS_APT:-not configured}).
EOF
}

ensure_nexus_repo() {
  if [[ ! -f "$NEXUS_APT" ]]; then
    log "NexusOS apt source not configured — using Debian mirrors only"
    return 0
  fi
  if [[ ! -f "$KEYRING" ]]; then
    log "WARN: NexusOS archive keyring missing at ${KEYRING}"
  fi
}

refresh_apt() {
  ensure_nexus_repo
  log "Updating package indices (NexusOS repo + Debian)..."
  sudo apt-get update -qq
}

list_packages() {
  if [[ -f "$CATALOG" ]] && command -v python3 >/dev/null 2>&1; then
    python3 -c "
import json
with open('$CATALOG') as f:
    for p in json.load(f):
        print(f\"{p['name']:20} {p['summary']}\")
"
  else
    apt list --installed 2>/dev/null | head -30
  fi
}

search_packages() {
  local query="$1"
  refresh_apt
  apt-cache search "$query" 2>/dev/null || log "Package cache not available."
}

install_package() {
  local pkg="$1"
  log "Installing ${pkg}..."
  refresh_apt
  if apt-cache show "$pkg" >/dev/null 2>&1; then
    sudo apt-get install -y "$pkg"
  else
    die "Package not found in apt cache: ${pkg}"
  fi
  echo "$(date -Iseconds) install ${pkg}" >> /var/log/nexus/store.log 2>/dev/null || true
  log "Installed ${pkg}."
}

remove_package() {
  local pkg="$1"
  log "Removing ${pkg}..."
  sudo apt-get remove -y "$pkg"
  echo "$(date -Iseconds) remove ${pkg}" >> /var/log/nexus/store.log 2>/dev/null || true
  log "Removed ${pkg}."
}

interactive() {
  echo "╔══════════════════════════════════════╗"
  echo "║       NexusOS Software Center        ║"
  echo "╚══════════════════════════════════════╝"
  echo
  if [[ -f "$NEXUS_APT" ]]; then
    echo "Source: NexusOS APT repository"
    grep -v '^#' "$NEXUS_APT" | head -1
  fi
  echo
  list_packages
  echo
  read -r -p "Install package name (or Enter to exit): " pkg
  [[ -n "$pkg" ]] && install_package "$pkg"
}

case "${1:-}" in
  list) list_packages ;;
  refresh) refresh_apt; log "Package index updated." ;;
  install) install_package "${2:?Package name required}" ;;
  remove) remove_package "${2:?Package name required}" ;;
  search) search_packages "${2:?Search query required}" ;;
  help|--help|-h) usage ;;
  "") interactive ;;
  *) die "Unknown command: $1" ;;
esac
