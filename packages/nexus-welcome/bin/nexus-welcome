#!/usr/bin/env bash
# NexusOS first-boot welcome wizard.

set -euo pipefail

FLAG="/home/nexus/.nexus-welcome-done"

run_wizard() {
  echo
  echo "  ╔═══════════════════════════════════════════╗"
  echo "  ║     Welcome to NexusOS (preview)          ║"
  echo "  ║     Independent Linux distribution        ║"
  echo "  ╚═══════════════════════════════════════════╝"
  echo
  echo "  Engineering preview — see /usr/share/nexusos/DISCLAIMER.md"
  echo

  local force_pw=0
  [[ -f /etc/nexusos/force-password-change ]] && force_pw=1

  if [[ "${1:-}" == "--non-interactive" && "$force_pw" -eq 0 ]]; then
    touch "$FLAG" 2>/dev/null || true
    return 0
  fi

  read -r -p "  Enter your display name [nexus]: " display_name
  display_name="${display_name:-nexus}"

  if [[ "$force_pw" -eq 1 ]]; then
    echo "  You must set a new password before continuing."
    passwd
    sudo rm -f /etc/nexusos/force-password-change 2>/dev/null || rm -f /etc/nexusos/force-password-change 2>/dev/null || true
  else
    read -r -p "  Change password now? [Y/n]: " change_pw
    if [[ "${change_pw:-Y}" != "n" && "${change_pw:-Y}" != "N" ]]; then
      passwd
    fi
  fi

  echo
  echo "  Quick start:"
  echo "    Firefox       — Web browser"
  echo "    nexus-store   — Install software"
  echo "    nexus-update  — System updates"
  echo "    nexus-settings about — System info"
  echo "    nexus-doctor  — Run diagnostics"
  echo

  touch "$FLAG"
  echo "  Setup complete. Enjoy NexusOS!"
  echo
}

if [[ -f "$FLAG" ]] && [[ "${1:-}" != "--force" ]]; then
  exit 0
fi

run_wizard "$@"
